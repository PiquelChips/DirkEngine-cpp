{
    "name": "Runtime",
    "c_standard": "c++23",
    "is_lib": true,
    "dependencies": [
        "Shaders"
    ],
    "external": [
        "glfw",
        "glm",
        "tinygltf",
        "vulkan"
    ],
    "defines": [
        "GLFW_INCLUDE_NONE",
        "GLFW_INCLUDE_VLUKAN",
        "LOG_PATH=\\\".\\\"",
        "RESOURCE_PATH=\\\".\\\"",
        "SHADER_PATH=\\\"Intermediate/Shaders\\\""
    ]
}
